generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Vault {
  id        String   @id @default(cuid())
  vaultCode String?  @unique  // User-friendly vault code for sharing (6 chars)
  name      String   @default("521")
  theme     String   @default("Pinky")
  font      String   @default("Default")
  startDate DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Security ────────────────────────────────────────────────────────────
  // Bcrypt-like hash of the vault passphrase (set on creation; legacy vaults = null)
  secretHash     String?
  secretSalt     String?
  hasSecurity    Boolean  @default(false)
  // 6-digit one-time pairing code, expires in 24h, used to add a second member
  pairingCode    String?
  pairingExpiresAt DateTime?

  members   VaultMember[]
  messages  Message[]
  memories  Memory[]
  events    SanctuaryEvent[]
  letters   LoveLetter[]
  aiChats      AiChatMessage[]
  sessions     Session[]
  gameSessions GameSession[]
}

model VaultMember {
  id        String   @id @default(cuid())
  vaultId   String
  role      String   @default("partner1")
  name      String   @default("Me")
  photoUrl  String?
  mood      String   @default("😊")
  moodUpdatedAt DateTime?
  isOnline  Boolean  @default(false)
  lastSeen  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Per-member auth ─────────────────────────────────────────────────────
  // PBKDF2-SHA256 of (passphrase + salt), base64. 100k iterations.
  passwordHash String?
  passwordSalt String?
  // Soft lock: bumps on failed login attempts; lockout at 5
  failedAttempts Int      @default(0)
  lockedUntil   DateTime?

  vault     Vault    @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  messages  Message[]
  sessions  Session[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique  // random 32 bytes hex
  memberId  String
  vaultId   String
  expiresAt DateTime
  lastUsedAt DateTime @default(now())
  createdAt DateTime @default(now())

  member VaultMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  vault  Vault       @relation(fields: [vaultId], references: [id], onDelete: Cascade)
}

model Message {
  id           String   @id @default(cuid())
  vaultId      String
  senderId     String
  text         String?
  imageUrl     String?
  audioUrl     String?
  videoUrl     String?
  documentUrl  String?
  replyToId    String?
  replyToText  String?
  replyToSender String?
  status       String   @default("sent")
  deleted      Boolean  @default(false)
  starred      Boolean  @default(false)
  reactions    String   @default("[]")
  messageType  String   @default("text")
  fileName     String?
  fileSize     Int?
  createdAt    DateTime @default(now())

  vault     Vault       @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  sender    VaultMember @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

model Memory {
  id          String   @id @default(cuid())
  vaultId     String
  content     String
  imageUrl    String?
  category    String   @default("General")
  revealDate  DateTime?
  createdAt   DateTime @default(now())

  vault       Vault    @relation(fields: [vaultId], references: [id], onDelete: Cascade)
}

model SanctuaryEvent {
  id        String   @id @default(cuid())
  vaultId   String
  title     String
  date      DateTime
  type      String   @default("Date")
  createdAt DateTime @default(now())

  vault     Vault    @relation(fields: [vaultId], references: [id], onDelete: Cascade)
}

model LoveLetter {
  id        String   @id @default(cuid())
  vaultId   String
  fromRole  String
  toRole    String
  content   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  vault     Vault    @relation(fields: [vaultId], references: [id], onDelete: Cascade)
}

model AiChatMessage {
  id        String   @id @default(cuid())
  vaultId   String
  role      String
  text      String
  createdAt DateTime @default(now())

  vault     Vault    @relation(fields: [vaultId], references: [id], onDelete: Cascade)
}

model GameSession {
  id             String   @id @default(cuid())
  vaultId        String
  status         String   @default("active") // active, completed, abandoned
  questionOrder  String   @default("[]") // JSON array of question indices
  currentIndex   Int      @default(0)
  scoreBatman    Int      @default(0)
  scorePrincess  Int      @default(0)
  // Per-question answer state: JSON { questionIndex: { batman: number|null, princess: number|null, revealedAt: number|null } }
  answers        String   @default("{}")
  // When the current question's timer started (ms epoch); null if waiting for an answer
  currentStartedAt DateTime?
  // When the current question's timer ends (ms epoch)
  currentEndsAt    DateTime?
  startedAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  completedAt    DateTime?

  vault          Vault    @relation(fields: [vaultId], references: [id], onDelete: Cascade)
}
