rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Shared vault for the couple
    match /couples/{coupleId} {
      // Require the ID to be non-obvious/long and allow access based on the ID as a secret key
      allow read, write: if coupleId is string && coupleId.size() >= 10;
    }

    // Interactive game sessions - tied to coupleId
    match /sessions/{sessionId} {
      allow read, write: if sessionId is string && sessionId.size() >= 10;
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
